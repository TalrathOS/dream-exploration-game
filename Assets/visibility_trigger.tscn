[gd_scene format=3 uid="uid://dd1endxbvry67"]

[sub_resource type="GDScript" id="GDScript_fw4o8"]
resource_name = "VisibilityTrigger"
script/source = "extends Area3D

@export var targets: Array[Node]
@export var state: bool
@export var reusable: bool

func _ready() -> void:
	$MeshInstance3D.free()

func _on_body_entered(body: Node3D) -> void:
	if visible:
		for thing in targets:
			thing.visible = state
		if !reusable:
			queue_free()
"

