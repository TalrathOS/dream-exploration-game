[gd_scene format=3 uid="uid://dd81o3vn1r8i5"]

[sub_resource type="GDScript" id="GDScript_g7o2m"]
resource_name = "StatPickupFloatType"
script/source = "extends Node3D

@export var target: String
@export var amount: float
@export var label: String

func _ready() -> void:
	$Label3D.text = label

func _on_area_3d_body_entered(body: Node3D) -> void:
	if (body.name == \"Player\") and visible:
		Globals.playerStats[target] += amount
		body.updateStats()
		print(target + \" increased by \" + str(amount))
		queue_free()
"

[sub_resource type="SphereMesh" id="SphereMesh_55kc7"]

[sub_resource type="SphereShape3D" id="SphereShape3D_fs37c"]

