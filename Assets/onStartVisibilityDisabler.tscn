[gd_scene format=3 uid="uid://be80lp78yfnrh"]

[sub_resource type="GDScript" id="GDScript_maaha"]
resource_name = "VisibilityTrigger"
script/source = "extends Node3D

@export var targets: Array[Node]


func _ready() -> void:
	for thing in targets:
		thing.visible = false
	queue_free()
"

[node name="OnStartVisibilityDisabler" type="Node3D" unique_id=1310696112]
script = SubResource("GDScript_maaha")
